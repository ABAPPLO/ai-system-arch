{
  "annotations": {"list": []},
  "title": "APIHub · Alerts Overview",
  "uid": "apihub-alerts",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 39,
  "tags": ["apihub", "alerts"],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "severity",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "Prometheus"},
        "query": "label_values(ALERTS, severity)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Active Alerts (total)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(ALERTS{alertstate=\"firing\"})", "legendFormat": "active"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "P0 firing",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum(ALERTS{alertstate=\"firing\", severity=\"P0\"})"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "P1 firing",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(ALERTS{alertstate=\"firing\", severity=\"P1\"})"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "P2 firing",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "sum(ALERTS{alertstate=\"firing\", severity=\"P2\"})"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 10}
            ]
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Firing alerts (detail)",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\", severity=~\"$severity\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "Value": true},
            "renameByName": {
              "alertname": "Alert",
              "severity": "Sev",
              "team": "Team",
              "api_id": "API",
              "instance": "Instance"
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Alerts fired (last 24h)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (severity) (changes(ALERTS{alertstate=\"firing\"}[1h]))",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "linear"}
        }
      }
    },
    {
      "type": "stat",
      "title": "Top API by alerts (24h)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
      "targets": [
        {
          "expr": "topk(10, sum by (api_id, alertname) (increase(ALERTS{alertstate=\"firing\"}[24h])))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
