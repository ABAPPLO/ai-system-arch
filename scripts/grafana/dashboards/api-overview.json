{
  "annotations": {"list": []},
  "title": "APIHub 调用总览（dev）",
  "uid": "apihub-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["apihub"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "总 QPS（5min）",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(apihub_http_requests_total[5m]))", "legendFormat": "QPS"}
      ]
    },
    {
      "type": "stat",
      "title": "错误率",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum(rate(apihub_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(apihub_http_requests_total[5m]))", "legendFormat": "5xx %"}
      ]
    },
    {
      "type": "stat",
      "title": "P99 延迟",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum(rate(apihub_http_request_duration_seconds_bucket[5m])) by (le))"}
      ]
    },
    {
      "type": "stat",
      "title": "Kafka lag",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "sum(kafka_consumergroup_lag)", "legendFormat": "lag"}
      ]
    },
    {
      "type": "timeseries",
      "title": "QPS by API",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum by (api_id) (rate(apihub_http_requests_total[5m]))", "legendFormat": "{{api_id}}"}
      ]
    }
  ]
}
