# 复制为 .env.dev 并按需修改（不要提交 .env.dev）
# docker compose --env-file .env.dev -f docker-compose.dev.yml up -d

# ============ PostgreSQL ============
# 业务服务连 apihub_app（NOSUPERUSER NOBYPASSRLS）—— RLS 才能生效
# apihub 是 superuser，仅用于 DDL/migration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=apihub
PG_USER=apihub_app
PG_PASSWORD=apihub_app_dev_pwd

# 业务服务读 PG 用（CI 注入到 .env）
PG_POOL_MIN=10
PG_POOL_MAX=50
# asyncpg ssl 值：dev 默认 disable（容器 PG 没 SSL）；prod 必须 require/verify-full
PG_SSL=disable

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=apihub_dev_pwd
REDIS_SSL=false

# ============ Kafka ============
# 业务代码用：localhost:9094（compose 映射的 EXTERNAL 端口）
# 容器内服务用：kafka:9092
KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC_CALL_EVENTS=api-call-events
KAFKA_TOPIC_TASK_REQUESTS=task-requests
KAFKA_TOPIC_TASK_STATUS=task-status
KAFKA_TOPIC_RETRY_REQUESTS=retry-requests
KAFKA_TOPIC_AUDIT_EVENTS=audit-events
KAFKA_TOPIC_NOTIFICATION=notification

# ============ ClickHouse ============
CH_HOST=localhost
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000
CH_USERNAME=apihub
CH_PASSWORD=apihub_dev_pwd
CH_DATABASE=apihub

# ============ MinIO ============
MINIO_ENDPOINT=http://localhost:9000
MINIO_USER=apihub
MINIO_PASSWORD=apihub_dev_pwd
MINIO_BUCKET_CALL_BODIES=call-bodies
MINIO_BUCKET_SDK=sdk-packages
MINIO_BUCKET_AUDIT=audit-archive

# ============ OTel / Jaeger ============
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev
JAEGER_UI=http://localhost:16686

# ============ 业务服务 ============
ENV=dev
LOG_LEVEL=DEBUG
APISIX_ADMIN_URL=http://localhost:9180
APISIX_ADMIN_KEY=REPLACE_ME

# HMAC 签名密钥加密 key（AES-256-GCM，32 字节 hex = 64 字符）—— R2e
# 独立于 AI_GATEWAY_ENCRYPTION_KEY（爆炸半径隔离）；prod 必须注入，缺则启动 fail-closed
HMAC_SECRET_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Auth service（apihub_core.auth 调用）
# 本地 dev：直连本地 auth-svc；prod：K8s 集群内 DNS
AUTH_SERVICE_URL=http://localhost:8002/v1/apikey/verify

# 下游服务 URL（admin-bff 聚合 / retry-svc 回调用）
# K8s 集群内 DNS；dev 覆盖到 localhost:端口
TENANT_SERVICE_URL=http://localhost:8005/v1/tenant
EXECUTOR_SERVICE_TEMPLATE=http://localhost:{port}/v1/internal/retry

# ============ Grafana ============
GRAFANA_PASSWORD=admin
